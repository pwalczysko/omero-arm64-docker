# Copy this file to .env and fill in your values before running docker compose.

# Override pre-built GHCR images with locally built ones (optional).
# After running: python3 build.py
# OMERO_SERVER_IMAGE=ghcr.io/simonhard/omero-server-arm64:latest
# OMERO_WEB_IMAGE=ghcr.io/simonhard/omero-web-arm64:latest

# Trusted origins for CSRF when using a reverse proxy. Must match the URL you
# use to access OMERO.web. Default covers localhost:8094.
# OMERO_WEB_CSRF_TRUSTED_ORIGINS='["http://127.0.0.1:8094","http://localhost:8094"]'

# PostgreSQL credentials
OMERO_DB_USER=omero
OMERO_DB_PASS=changeme
OMERO_DB_NAME=omero

# OMERO root (admin) password
OMERO_ROOT_PASS=changeme
